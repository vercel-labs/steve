# Managed by Ansible (monitoring role).
# Beszel hub (dashboard) + agent, monitoring this droplet.
#
# First-run handshake: after the stack is up, open the hub at
# https://{{ monitoring_domain }}, create your admin account, then "Add System"
# with host 127.0.0.1 and port {{ beszel_agent_port }}. The hub will show the
# public key to authorize; paste it into deploy/group_vars/all.yml as
# `beszel_agent_key` and re-run deploy (or set it in the hub's add-system flow,
# which writes it to the agent on connect). See deploy/README.md.
services:
  beszel:
    image: henrygd/beszel@sha256:a849ad80814b6a1a3be665304dcace5d4854b3bed7bde4dd1227e8ce1b82d477
    container_name: beszel-hub
    restart: unless-stopped
    # Hub UI bound to localhost; Caddy terminates TLS and proxies to it.
    ports:
      - "127.0.0.1:{{ beszel_hub_port }}:8090"
    volumes:
      - ./hub_data:/beszel_data

  beszel-agent:
    image: henrygd/beszel-agent@sha256:8874e2c53f9de5e063a6a80d6b617e20fa593ac5dc4eb4c6ce1f912f510f38f8
    container_name: beszel-agent
    restart: unless-stopped
    network_mode: host
    environment:
      LISTEN: "{{ beszel_agent_port }}"
      # Public key + token from the hub's "Add System" flow.
      KEY: "{{ beszel_agent_key | default('') }}"
{% if beszel_agent_token | default('') | length > 0 %}
      TOKEN: "{{ beszel_agent_token }}"
      HUB_URL: "{{ beszel_hub_url | default('http://127.0.0.1:' ~ beszel_hub_port) }}"
{% endif %}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./agent_data:/var/lib/beszel-agent
