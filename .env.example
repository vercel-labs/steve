# --- Model: direct provider (NO AI Gateway) ---
# agent.ts passes a provider object (not a string id), which bypasses the Vercel
# AI Gateway and calls the provider directly. Set ONE of the keys below:
#   - OPENAI_API_KEY is used by default (gpt-5-mini).
#   - ANTHROPIC_API_KEY is the fallback (claude-haiku-4-5), used when
#     OPENAI_API_KEY is unset.
OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."

# --- Durability: self-hosted Postgres Workflow world ---
# Read by @workflow/world-postgres at runtime. Matches docker-compose.yml.
WORKFLOW_POSTGRES_URL="postgres://world:world@localhost:5544/world"
# The workflow CLI (inspect/web) reads this as its default --backend. It must
# match the world package selected in agent/agent.ts.
WORKFLOW_TARGET_WORLD="@workflow/world-postgres"
# REQUIRED: must be "eve" so the world's queue names match eve's registered
# handler prefix (__eve_wkf_workflow_). Without it every job 400s with
# "Unhandled queue".
WORKFLOW_QUEUE_NAMESPACE="eve"
# Optional tuning (defaults are fine for the PoC):
# WORKFLOW_POSTGRES_WORKER_CONCURRENCY="4"

# --- Route auth (VPS): HTTP Basic ---
# Wired into httpBasic() in agent/channels/eve.ts.
ROUTE_AUTH_BASIC_USER="admin"
ROUTE_AUTH_BASIC_PASSWORD="change-me"

# --- Isolation proof: a host-only secret the sandbox must NOT be able to read ---
HOST_ONLY_SECRET="if-you-can-read-this-from-the-sandbox-isolation-is-broken"

# --- Observability: pick ONE backend (or neither to disable) ---
# agent/instrumentation.ts selects the backend from these env vars, in this
# precedence order; if neither is set, telemetry export is disabled (fail-open).
#
# Option A — Observe SDK -> local dashboard (the local default). Set
# OPEN_OBSERVE_OTLP_ENDPOINT to enable. observe(...) from @open-observe/sdk
# exports traces, logs, and metrics to the local Observe dashboard. Start it
# from the openobserve checkout with:
#   pnpm --filter @open-observe/dashboard dev
# then open http://localhost:3001/p/steve. Takes precedence over Option B.
OPEN_OBSERVE_OTLP_ENDPOINT="http://localhost:3001"
OPEN_OBSERVE_PROJECT_ID="steve"
#
# Option B — vanilla OTel -> self-hosted Jaeger (the production default). Used
# when OPEN_OBSERVE_OTLP_ENDPOINT is unset. Start Jaeger locally with
# `docker compose --profile observability up -d jaeger`; on the VPS the deploy
# runs it automatically and exposes the UI at jaeger.<domain>. Traces go to
# <endpoint>/v1/traces.
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"

# --- Deploy-time only (Ansible): NOT read by the app at runtime ---
# These configure the DigitalOcean deploy (deploy/) when it renders the Beszel
# and Jaeger config. Like DO_API_TOKEN, they are read from your SHELL environment
# (not from this file) — export them before `ansible-playbook deploy.yml` (or
# `make -C deploy deploy`). Listed here only for discoverability; nothing here is
# sensitive, so you can reuse the demo values below. See deploy/README.md.
#
# Beszel monitoring agent token, from the hub's "Add System" flow. Leave unset
# until the hub gives you one; the demo droplet used the value below.
# export BESZEL_AGENT_TOKEN="25d09c13-7c39-432f-8864-7f6f84a4a334"
#
# Jaeger trace UI HTTP Basic auth. USER defaults to `eve`; HASH is a bcrypt hash
# (generate with: caddy hash-password --plaintext '<password>'). If HASH is unset
# the Jaeger UI is served without auth. The demo login is `eve` / `justshipthings`
# (single-quote the hash so the shell doesn't expand the `$` segments):
# export JAEGER_BASIC_AUTH_USER="eve"
# export JAEGER_BASIC_AUTH_HASH='$2a$14$bJVPqzWhGCf0.G/T9MC6peaH5BckzStlmz3PMl/Q8hhzf0eTgOjRC'

# --- FORBIDDEN: do NOT set these (they re-introduce Vercel coupling) ---
# AI_GATEWAY_API_KEY=...
# VERCEL_OIDC_TOKEN=...
