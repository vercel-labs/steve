# Direct model provider. Set exactly one; OpenAI wins when both are present.
OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

# Production route protection. Local loopback requests use Eve's localDev()
# policy; every non-loopback request requires these Basic credentials.
ROUTE_AUTH_BASIC_USER="admin"
ROUTE_AUTH_BASIC_PASSWORD="replace-with-a-long-random-password"

# PostgreSQL container and host binding. If the password contains URL-reserved
# characters, percent-encode it in WORKFLOW_POSTGRES_URL.
POSTGRES_USER="world"
POSTGRES_PASSWORD="replace-with-a-long-random-password"
POSTGRES_DB="world"
POSTGRES_HOST_PORT="5544"

# Durable Workflow world. WORKFLOW_TARGET_WORLD is used by the Workflow CLI;
# Eve selects the same package in agent/agent.ts.
WORKFLOW_POSTGRES_URL="postgres://world:replace-with-a-long-random-password@127.0.0.1:5544/world"
WORKFLOW_TARGET_WORLD="@workflow/world-postgres"
WORKFLOW_POSTGRES_WORKER_CONCURRENCY="10"
WORKFLOW_POSTGRES_MAX_POOL_SIZE="12"

# Used only by the isolation verification. This value must never appear inside
# a sandbox command result.
HOST_ONLY_SECRET="host-only-verification-value"

# Optional OpenTelemetry export. The standard OTLP variables work with Jaeger,
# OpenObserve, and other OTLP/HTTP collectors. Prompt/output recording defaults
# to false and should be enabled only after reviewing the collector's retention.
# OTEL_EXPORTER_OTLP_ENDPOINT="http://127.0.0.1:4318"
# OTEL_EXPORTER_OTLP_HEADERS="authorization=Basic%20..."
OTEL_RECORD_INPUTS="false"
OTEL_RECORD_OUTPUTS="false"

# Optional link shown in the web UI. It is embedded at Next.js build time.
# NEXT_PUBLIC_MONITORING_URL="https://status.example.com"

# Deployment-only values are read from the operator's shell, not this file:
# DO_API_TOKEN, BESZEL_AGENT_TOKEN, JAEGER_BASIC_AUTH_USER,
# JAEGER_BASIC_AUTH_HASH.
